{
  "name": "astro-shadcn",
  "type": "module",
  "description": "Astro template based on shadcn, @base-ui, tailwind",
  "version": "1.0.0",
  "scripts": {
    "clean": "rm -rf node_modules .astro dist",
    "refresh": "pnpm dlx @astrojs/upgrade; pnpm up -L",
